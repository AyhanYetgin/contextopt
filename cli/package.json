{
  "name": "contextopt",
  "version": "0.1.0",
  "description": "MCP Context Optimizer - Reduce AI agent token waste by 60-90%",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "contextopt": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AyhanYetgin/contextopt.git"
  },
  "keywords": [
    "mcp",
    "context",
    "optimizer",
    "claude",
    "cursor",
    "windsurf",
    "token",
    "ai",
    "agent"
  ],
  "author": "Ayhan Yetgin",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
